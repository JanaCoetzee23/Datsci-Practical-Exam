library(tidyverse)
list.files('code/', full.names = T, recursive = T) %>%
as.list() %>% walk(~source(.))
readr::guess_encoding("../data/Coffee/Coffee.csv")
readr::guess_encoding("../data/Coffee/Coffee.csv")
readr::guess_encoding("data/Coffee/Coffee.csv")
test_utf8 <- read_csv("data/Coffee/Coffee.csv", locale = locale(encoding = "UTF-8"), n_max = 5)
test_utf8$desc_1[1]
test_1252 <- read_csv("data/Coffee/Coffee.csv", locale = locale(encoding = "windows-1252"), n_max = 5)
test_1252$desc_1[1]
test_utf8_full <- read_csv("data/Coffee/Coffee.csv", locale = locale(encoding = "UTF-8"))
test_1252_full <- read_csv("data/Coffee/Coffee.csv", locale = locale(encoding = "windows-1252"))
# Row 2 had the â€œ issue in your screenshot:
test_utf8_full$name[2]
test_1252_full$name[2]
# Search for the row containing "Sweety" or the encoding artifact directly:
test_utf8_full$name[grepl("Sweety", test_utf8_full$name)]
test_1252_full$name[grepl("Sweety", test_1252_full$name)]
# Also check generally for any remaining artifacts across the whole column:
sum(grepl("â€", test_utf8_full$name))
sum(grepl("â€", test_1252_full$name))
Load_Coffee <- function(path){
hushread <- purrr::quietly(read_csv)
df <- hushread(path, locale = locale(encoding = "UTF-8"))
df$result
}
Coffee <- Load_Coffee("data/Coffee/Coffee.csv")
# Clean up test objects, we don't need them anymore:
rm(test_utf8, test_1252, test_utf8_full, test_1252_full)
glimpse(Coffee)
