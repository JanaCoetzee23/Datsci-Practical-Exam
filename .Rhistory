library(tidyverse)
list.files('Question_1/code/', full.names = T, recursive = T) %>%
as.list() %>% walk(~source(.))
Coffee <- Load_Coffee("data/Coffee/Coffee.csv")
Coffee <- Coffee %>% Extract_Region()
Top_Value_Coffees(Coffee, Top_N = 10) %>%
mutate(Value_Score = round(Value_Score, 1)) %>%
knitr::kable(digits = 2,
col.names = c("Coffee", "Roaster", "Region", "Roast",
"Rating", "Cost/100g ($)", "Value Score"))
Top_Value_Coffees(Coffee, Top_N = 10) %>%
mutate(Value_Score = round(Value_Score, 1)) %>%
knitr::kable(digits = 2,
col.names = c("Coffee", "Roaster", "Region", "Roast",
"Rating", "Cost/100g ($)", "Value Score"),
caption = "Value Score = Rating / Cost per 100g. Note: the top entry is unusually cheap relative to the rest of the dataset.")
Top_Value_Coffees(Coffee, Top_N = 10) %>%
mutate(Value_Score = round(Value_Score, 1)) %>% head (5) %>%
knitr::kable(digits = 2,
col.names = c("Coffee", "Roaster", "Region", "Roast",
"Rating", "Cost/100g ($)", "Value Score"),
caption = "Value Score = Rating / Cost per 100g. Note: the top entry is unusually cheap relative to the rest of the dataset.")
