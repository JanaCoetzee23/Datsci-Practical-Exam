library(tidyverse)
list.files('code/', full.names = T, recursive = T) %>%
as.list() %>% walk(~source(.))
Coffee <- Load_Coffee("data/Coffee/Coffee.csv")
glimpse(Coffee)
Coffee %>% select(origin_1, origin_2) %>% head(10)
n_distinct(Coffee$origin_1)
n_distinct(Coffee$origin_2)
sum(is.na(Coffee$origin_1))
sum(is.na(Coffee$origin_2))
Coffee %>% pull(origin_1) %>% unique() %>% sort()
Coffee %>% count(Region) %>% arrange(desc(n))
